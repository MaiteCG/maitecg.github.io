---
import MainLayout from "../layouts/MainLayout.astro";
import { SITE } from "../config/site";
import { Icon } from "astro-icon/components";
---

<MainLayout title={`${SITE.name} | Researcher in Cognitive Neuroscience and Visual Artist`}>
  <section class="hero">
     
    <p class="eyebrow">{SITE.role}</p>
    <h1>{SITE.name}</h1>
    
    <div class="hero-with-photo">
      <div class="hero-text">

        <p class="hero-subtitle">
          Exploring the neural mechanisms of memory, cognitive control, and healthy
          ageing, with a particular interest in the role of brain oscillations in
          human cognition.
        </p>

        <p class="hero-methods">
          Using behavioural experiments, large-scale data analysis, multimodal
          neuroimaging (EEG, MEG, and fMRI), and non-invasive brain stimulation (rTMS).
        </p>

        <div class="hero-icons">

          <a
            href={SITE.links.mrc_cbu}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="MRC Cognition and Brain Sciences Unit"
          >
            <img
              src="/images/MRC_CBU_small_logo.png"
              alt="MRC Cognition and Brain Sciences Unit"
              class="profile-icon"
            />
          </a>

          <a
            href={SITE.links.scholar}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Google Scholar"
          >
            <Icon name="simple-icons:googlescholar" />
          </a>

          <a
            href={SITE.links.orcid}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="ORCID"
          >
            <Icon name="simple-icons:orcid" />
          </a>
        
          <a
            href={SITE.links.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
          >
            <Icon name="simple-icons:linkedin" />
          </a>
        
          <a
            href={SITE.links.github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
          >
            <Icon name="simple-icons:github" />
          </a>        
        </div>
      </div>

      <div class="hero-photo-wrap">
        <img
          src="/images/profile.jpg"
          alt="Portrait of Maite Crespo-Garcia"
          class="hero-photo"
        />
      </div>
    </div>
  </section>

  <section>
    <h2>Current position</h2>
    <p>
      Postdoctoral Research Associate, MRC Cognition and Brain Sciences Unit, University of Cambridge.
    </p>
    <p class="pages-names">Email: <span> <a href="mailto:maite.crespo-garcia@mrc-cbu.cam.ac.uk">maite.crespo-garcia@mrc-cbu.cam.ac.uk</a></span></p>
  </section>

  <section>
    <h2>Research at a glance</h2>
    
    <ul>
      <li> Healthy Ageing and Brain Dynamics</li>
      <li> Memory Suppression and Inhibitory Mechanisms</li>
      <li> Brain Oscillations and Memory Processes</li>
      <li> Hippocampal Dynamics with Magnetoencephalography</li>
    </ul>
    
    <p class="pages-names">→ Explore my <a href="/research">Research</a>.</p>
  </section>

  <section>
    <h2>Art</h2>
    <p>
      Alongside my scientific research, I enjoy drawing portraits with pen and ink and exploring other artistic techniques.
    </p>
    <p class="pages-names">→ Visit the <a href="/art">Art</a> gallery.</p>
  </section>
</MainLayout>
