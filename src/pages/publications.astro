---
import MainLayout from "../layouts/MainLayout.astro";
import { SITE } from "../config/site";
import { parse } from "csv-parse/sync";
import fs from "node:fs";

type Publication = {
  year: string;
  title: string;
  authors: string;
  journal: string;
  doi?: string;
  pdf?: string;
  code?: string;
  abstract?: string;
};

function formatDoiUrl(doi?: string, journal?: string) {
  if (!doi) return "";

  const cleanDoi = doi.trim();
  const cleanJournal = journal?.trim().toLowerCase() || "";

  if (cleanDoi.startsWith("http")) {
    return cleanDoi;
  }

  if (cleanJournal.includes("biorxiv")) {
    return `https://www.biorxiv.org/content/${cleanDoi}`;
  }

  return `https://doi.org/${cleanDoi}`;
}

const csv = fs.readFileSync("src/data/publications.csv", "utf-8");

const rawPublications = parse(csv, {
  columns: true,
  skip_empty_lines: true,
  bom: true,
});

const publications = rawPublications
  .map((pub: any) => ({
    year: pub.year || pub.Year || "",
    title: pub.title || pub.Title || "",
    authors: pub.authors || pub.Authors || "",
    journal: pub.journal || pub.Journal || "",
    doi: pub.doi || pub.DOI || "",
    pdf: pub.pdf || pub.PDF || "",
    code: pub.code || pub.Code || "",
    abstract: pub.abstract || pub.Abstract || "",
  }))
  .sort((a: Publication, b: Publication) => Number(b.year) - Number(a.year));
---

<MainLayout title={`Publications | ${SITE.name}`}>
  <section class="page-intro">
    <h1>Publications</h1>
  </section>

  <section class="publication-list">
    {publications.map((pub) => (
      <article class="publication">
        <div class="publication-year-inline">{pub.year}</div>

        <div class="publication-main">
          <h2>{pub.title}</h2>

          <p class="publication-authors">{pub.authors}</p>

          <p class="publication-venue">
            <span class="publication-journal">{pub.journal}.</span>
            <span> doi: </span>
            <span class="publication-doi">
              {pub.doi && (
                <a
                  href={formatDoiUrl(pub.doi, pub.journal)}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {pub.doi}
                </a>
              )}
            </span>
          </p>

          <div class="publication-links">            

            {pub.pdf && (
              <a href={pub.pdf} target="_blank" rel="noopener noreferrer">
                PDF
              </a>
            )}

            {pub.code && (
              <a href={pub.code} target="_blank" rel="noopener noreferrer">
                Code
              </a>
            )}
          </div>

          {pub.abstract && (
            <details class="publication-abstract">
              <summary>Abstract</summary>
              <p>{pub.abstract}</p>
            </details>
          )}
        </div>
      </article>
    ))}
  </section>
</MainLayout>