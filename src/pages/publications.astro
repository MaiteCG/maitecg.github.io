---
import MainLayout from "../layouts/MainLayout.astro";
import publicationsJson from "../data/publications.json";
import { SITE } from "../config/site";
/*import { parse } from "csv-parse/sync";
import fs from "node:fs";*/


type Publication = {
  year: string | number;
  title: string;
  authors: string;
  journal: string;
  venue: string;
  volume_issue_pages?: string;
  doi?: string;
  link?: string;
  pdf?: string;
  code?: string;
  abstract?: string;
  status?: "in_preparation" | "preprint" | "published";
};


const allPublications = (publicationsJson as Publication[]).sort(
(a, b) => Number(b.year) - Number(a.year)
);

const inPreparation = allPublications.filter(
(pub) => pub.status === "in_preparation"
);

const preprints = allPublications.filter(
(pub) => pub.status === "preprint"
);

const published = allPublications.filter(
(pub) => !pub.status || pub.status === "published"
);

function getPublicationLink(pub: Publication) {
if (pub.link) return pub.link;

if (!pub.doi) return "";

const cleanDoi = pub.doi.trim();

if (cleanDoi.startsWith("http")) {
  return cleanDoi;
}

return `https://doi.org/${cleanDoi}`;
}
---

<MainLayout title={`Publications | ${SITE.name}`}>
<section class="page-intro">
  <h1>Publications</h1>
</section>

{inPreparation.length > 0 && (
  <section class="publication-list">
    <h2 class="publication-section-title">In preparation</h2>
    {inPreparation.map((pub) => (
      <article class="publication">
        <div class="publication-year-inline">{pub.year}</div>

        <div class="publication-main">
          <h2>{pub.title}</h2>
          <p class="publication-authors" set:html={pub.authors}></p>

          <!-- There is no venue, journal, or DOI for publications in preparation, so we skip that section. -->
          {pub.abstract && (
            <details class="publication-abstract">
              <summary>Abstract</summary>
              <p>{pub.abstract}</p>
            </details>
          )}
        </div>
      </article>
    ))}
  </section>
)}

{preprints.length > 0 && (
  <section class="publication-list">
    <h2 class="publication-section-title">Preprints</h2>
    {preprints.map((pub) => (
      <article class="publication">
        <div class="publication-year-inline">{pub.year}</div>

        <div class="publication-main">
          <h2>{pub.title}</h2>
          <p class="publication-authors" set:html={pub.authors}></p>

          <p class="publication-venue">
            <span class="publication-journal">{pub.venue || pub.journal}</span>
            {pub.volume_issue_pages && <span>, {pub.volume_issue_pages}</span>}
            <span>.</span>

            {pub.doi && (
              <>
                <span> DOI: </span>
                <span class="publication-doi">
                  <a href={getPublicationLink(pub)} target="_blank" rel="noopener noreferrer">
                    {pub.doi}
                  </a>
                </span>
              </>
            )}
          </p>

          {pub.abstract && (
            <details class="publication-abstract">
              <summary>Abstract</summary>
              <p>{pub.abstract}</p>
            </details>
          )}
        </div>
      </article>
    ))}
  </section>
)}

{published.length > 0 && (
  <section class="publication-list">
    <h2 class="publication-section-title">Published papers</h2>
    {published.map((pub) => (
      <article class="publication">
        <div class="publication-year-inline">{pub.year}</div>

        <div class="publication-main">
          <h2>{pub.title}</h2>
          <p class="publication-authors" set:html={pub.authors}></p>

          <p class="publication-venue">
            <span class="publication-journal">{pub.venue || pub.journal}</span>
            {pub.volume_issue_pages && <span>, {pub.volume_issue_pages}</span>}
            <span>.</span>

            {pub.doi && (
              <>
                <span> DOI: </span>
                <span class="publication-doi">
                  <a href={getPublicationLink(pub)} target="_blank" rel="noopener noreferrer">
                    {pub.doi}
                  </a>
                </span>
              </>
            )}
          </p>

          <div class="publication-links">
            {pub.pdf && (
              <a href={pub.pdf} target="_blank" rel="noopener noreferrer">
                PDF
              </a>
            )}

            {pub.code && (
              <a href={pub.code} target="_blank" rel="noopener noreferrer">
                Code
              </a>
            )}
          </div>

          {pub.abstract && (
            <details class="publication-abstract">
              <summary>Abstract</summary>
              <p>{pub.abstract}</p>
            </details>
          )}
        </div>
      </article>
    ))}
  </section>
)}
</MainLayout>