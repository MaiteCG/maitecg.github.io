---
import MainLayout from "../layouts/MainLayout.astro";
import { SITE } from "../config/site";
import { Icon } from "astro-icon/components";
---

<MainLayout title={`About | ${SITE.name}`}>
  <section class="page-intro">
    <h1>About</h1>

    <p>
      I am a Postdoctoral Research Associate at the MRC Cognition and Brain
      Sciences Unit, University of Cambridge, working on projects within CamCAN
      and the Memory Control Lab.
    </p>
  </section>

  <section class="about-content">
    <h2>Research profile</h2>

    <p>
      My research investigates the brain mechanisms underlying episodic memory,
      cognitive control, and healthy ageing, with a particular interest in the
      role of brain oscillations in human cognition.
    </p>

    <p>
      Since my PhD, I have combined behavioural experimentation with neuroimaging
      and brain stimulation methods, including intracranial EEG, scalp EEG, MEG,
      fMRI, and transcranial magnetic stimulation (TMS). I am also interested in
      advanced analytical approaches for integrating multimodal and large-scale
      datasets.
    </p>

    <h2>Biography</h2>

    <p>
      I earned my PhD in 2013 from the University Pablo de Olavide in Seville,
      Spain, under the supervision of Mercedes Atienza and José Luis Cantero.
    </p>

    <p>
      I then completed a postdoctoral position at the University of Konstanz in
      Sarang Dalal’s group, where I was also a member of the Zukunftskolleg as a
      Marie Curie Fellow.
    </p>

    <p>
      In 2017, I moved to Cambridge to join the MRC Cognition and Brain Sciences
      Unit and Michael Anderson’s group, supported by a Newton International
      Fellowship from the Royal Society. Since 2021, I have held a position as
      Research Associate.
    </p>
  </section>

  <section class="timeline">
    <h2>Career Path</h2>
  
    <div class="timeline-item">
      <div class="timeline-year">2021–Present</div>
  
      <div class="timeline-content">
        <h3>Research Associate</h3>
        <p>MRC Cognition and Brain Sciences Unit, University of Cambridge</p>
      </div>
    </div>
  
    <div class="timeline-item">
      <div class="timeline-year">2017–2021</div>
  
      <div class="timeline-content">
        <h3>Newton International Fellow / Postdoctoral Researcher</h3>
        <p>MRC Cognition and Brain Sciences Unit, University of Cambridge</p>
      </div>
    </div>
  
    <div class="timeline-item">
      <div class="timeline-year">2014–2017</div>
  
      <div class="timeline-content">
        <h3>Marie Curie Fellow & Postdoctoral Researcher</h3>
        <p>University of Konstanz</p>
      </div>
    </div>
  
    <div class="timeline-item">
      <div class="timeline-year">2009–2013</div>
  
      <div class="timeline-content">
        <h3>PhD in Neuroscience</h3>
        <p>University Pablo de Olavide, Seville</p>
      </div>
    </div>
  </section>

  <section class="expertise">
    <h2>Methods & Expertise</h2>
  
    <div class="expertise-grid">
      <div class="expertise-card">
        <h3>💻 Programming</h3>
        <div class="expertise-tags">
          <span>Python</span>
          <span>MATLAB</span>
          <span>R</span>
          <span>Bash</span>
        </div>
      </div>
  
      <div class="expertise-card">
        <h3>🧠 Neuroimaging</h3>
        <ul>
          <li>EEG</li>
          <li>MEG</li>
          <li>fMRI</li>
          <li>Intracranial EEG</li>
        </ul>
      </div>
  
      <div class="expertise-card">
        <h3>📊 Analysis</h3>
        <ul>
          <li>Signal Processing</li>
          <li>Machine Learning</li>
          <li>Statistics</li>
          <li>Data Integration</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="professional-development">
    <h2>🤖 Professional Development in AI & Data Science</h2>
  
    <p>
      I continue to expand my computational profile through recent training in
      artificial intelligence, machine learning, and data-oriented research
      methods.
    </p>
  
    <div class="training-list">
      <article class="training-item">
        <h3>Course or Workshop Title</h3>
        <p class="training-meta">Provider or Institution · 2026</p>
        <p>
          Brief description of the topics covered, such as machine learning,
          generative AI, data analysis, or responsible AI.
        </p>
      </article>
  
      <article class="training-item">
        <h3>Course or Workshop Title</h3>
        <p class="training-meta">Provider or Institution · 2025</p>
        <p>
          Brief description of the course or workshop.
        </p>
      </article>
    </div>
  </section>

  <section class="profiles">
    <h2>Profiles</h2>
  
    <ul class="profile-links">
      <li>
        <a href={SITE.links.orcid} target="_blank">
          <Icon name="simple-icons:orcid" />
          ORCID
        </a>
      </li>
  
      <li>
        <a href={SITE.links.scholar} target="_blank">
          <Icon name="simple-icons:googlescholar" />
          Google Scholar
        </a>
      </li>
  
      <li>
        <a href={SITE.links.github} target="_blank">
          <Icon name="simple-icons:github" />
          GitHub
        </a>
      </li>

      <li>
        <a href={SITE.links.linkedin} target="_blank">
          <Icon name="simple-icons:linkedin" />
          LinkedIn
        </a>
      </li>
    </ul>
  </section>
</MainLayout>